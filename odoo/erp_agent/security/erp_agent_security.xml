<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_erp_agent_conversation_own" model="ir.rule">
        <field name="name">erp_agent.conversation: own records only</field>
        <field name="model_id" ref="model_erp_agent_conversation"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_erp_agent_message_own" model="ir.rule">
        <field name="name">erp_agent.message: own records only</field>
        <field name="model_id" ref="model_erp_agent_message"/>
        <field name="domain_force">[('conversation_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_erp_agent_agent_own" model="ir.rule">
        <field name="name">erp_agent.agent: own records only</field>
        <field name="model_id" ref="model_erp_agent_agent"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_erp_agent_profile_own" model="ir.rule">
        <field name="name">erp_agent.profile: own records only</field>
        <field name="model_id" ref="model_erp_agent_profile"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
